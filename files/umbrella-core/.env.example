# ============================================================
# Umbrella Core — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://umbrella:changeme@localhost:5432/umbrella_core
# For sync operations (Alembic migrations)
DATABASE_URL_SYNC=postgresql+psycopg2://umbrella:changeme@localhost:5432/umbrella_core

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
# Must be a long random string. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret

# --- Initial Admin ---
# Discord ID of the first admin user (used to bootstrap the system)
INITIAL_ADMIN_DISCORD_ID=YOUR_DISCORD_ID_HERE

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8765
DEBUG=false

# --- Optional: will be moved to DB settings after first boot ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
RCON_HOST=localhost
RCON_PORT=25575
RCON_PASSWORD=
OPENROUTER_API_KEY=
